---
import { getCollection } from 'astro:content';

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

const t = {
  es: {
    label: 'BLOG',
    title: 'Lo que estamos',
    titleHighlight: 'aprendiendo',
    viewAll: 'Ver todos los articulos',
    noPosts: 'Proximamente publicaremos contenido',
    readMore: 'Leer mas',
  },
  en: {
    label: 'BLOG',
    title: 'What we are',
    titleHighlight: 'learning',
    viewAll: 'View all articles',
    noPosts: 'Content coming soon',
    readMore: 'Read more',
  }
};

const text = t[lang];
const prefix = lang === 'es' ? '' : '/en';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);
---

<section class="relative py-24 sm:py-32">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="fade-in flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-16">
      <div>
        <span class="section-label mb-4 block">{text.label}</span>
        <h2 class="text-4xl sm:text-5xl lg:text-6xl leading-[1.05]">
          {text.title}<br/>
          <span class="italic text-502-green">{text.titleHighlight}</span>
        </h2>
      </div>
      <a
        href={`${prefix}/blog`}
        class="inline-flex items-center gap-2 text-sm text-502-green hover:text-white transition-colors shrink-0"
      >
        {text.viewAll}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    {posts.length > 0 ? (
      <div class="grid sm:grid-cols-3 gap-4 sm:gap-6">
        {posts.map((post) => {
          const postTitle = lang === 'es' ? post.data.title : (post.data.titleEn || post.data.title);
          const postDesc = lang === 'es' ? post.data.description : (post.data.descriptionEn || post.data.description);
          const pubDate = new Date(post.data.pubDate + 'T12:00:00');
          const dateStr = pubDate.toLocaleDateString(lang === 'es' ? 'es-GT' : 'en-US', {
            year: 'numeric', month: 'short', day: 'numeric'
          });

          return (
            <a
              href={`${prefix}/blog/${post.slug}`}
              class="stagger-item group relative rounded-2xl border border-white/5 bg-502-surface/30 overflow-hidden hover:border-502-green/30 transition-all duration-300 glow-hover flex flex-col"
            >
              <!-- Image -->
              {post.data.image && (
                <div class="aspect-video overflow-hidden">
                  <img
                    src={post.data.image}
                    alt={postTitle}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  />
                </div>
              )}

              <!-- Content -->
              <div class="p-6 flex flex-col flex-1">
                <div class="flex items-center gap-2 text-xs text-gray-500 mb-3">
                  <time>{dateStr}</time>
                  {post.data.author && (
                    <>
                      <span class="w-1 h-1 rounded-full bg-gray-600"></span>
                      <span>{post.data.author}</span>
                    </>
                  )}
                </div>
                <h3 class="text-lg mb-2 group-hover:text-502-green transition-colors leading-snug">
                  {postTitle}
                </h3>
                <p class="text-gray-500 text-sm line-clamp-2 flex-1">{postDesc}</p>
                <span class="mt-4 text-xs text-502-green group-hover:text-white transition-colors">
                  {text.readMore} &rarr;
                </span>
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="text-center text-gray-500 py-16 border border-white/5 rounded-2xl">
        <p>{text.noPosts}</p>
      </div>
    )}
  </div>
</section>
