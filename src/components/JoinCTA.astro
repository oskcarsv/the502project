---
interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

const t = {
  es: {
    label: 'UNETE',
    title: 'Listo para',
    titleHighlight: 'construir?',
    subtitle: 'Entra cuando quieras, participa como quieras. La comunidad vive en Discord y WhatsApp.',
    discord: 'Unirse al Discord',
    whatsapp: 'Unirse al WhatsApp',
    also: 'Tambien en',
  },
  en: {
    label: 'JOIN US',
    title: 'Ready to',
    titleHighlight: 'build?',
    subtitle: 'Join whenever you want, participate however you want. The community lives on Discord and WhatsApp.',
    discord: 'Join Discord',
    whatsapp: 'Join WhatsApp',
    also: 'Also on',
  }
};

const text = t[lang];

const links = {
  discord: 'https://discord.gg/AZeuYhCu',
  whatsapp: 'https://chat.whatsapp.com/JNvMJwm9Y0aDOBEQj3sFkM',
  linkedin: 'https://www.linkedin.com/company/the502project/',
  instagram: 'https://www.instagram.com/_the502project/',
  x: 'https://x.com/the502project',
  youtube: 'https://www.youtube.com/@the-502-project',
};
---

<section class="relative py-24 sm:py-32">
  <!-- Background - no overflow hidden, gradient bleeds naturally into adjacent sections -->
  <div class="absolute inset-x-0 -top-40 -bottom-40 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[500px] sm:w-[900px] sm:h-[750px] lg:w-[1200px] lg:h-[1000px] bg-502-green/[0.04] rounded-full blur-[250px]"></div>
  </div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="fade-in">
      <span class="section-label mb-6 block">{text.label}</span>

      <h2 class="text-5xl sm:text-6xl lg:text-7xl leading-[1.05] mb-6">
        {text.title}<br/>
        <span class="italic text-502-green">{text.titleHighlight}</span>
      </h2>

      <p class="text-gray-400 text-lg max-w-xl mx-auto mb-10">
        {text.subtitle}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
        <a
          href={links.discord}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-2.5 px-8 py-4 bg-502-green text-502-black text-sm font-bold rounded-full hover:bg-white transition-all hover:scale-105 active:scale-95 hover:shadow-[0_0_40px_rgba(86,239,159,0.3)]"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
          </svg>
          {text.discord}
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>

        <a
          href={links.whatsapp}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 border border-white/15 text-sm text-white rounded-full hover:border-502-green hover:text-502-green transition-all hover:bg-502-green/5"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          {text.whatsapp}
        </a>
      </div>

      <!-- Social links -->
      <p class="text-gray-500 text-sm">
        {text.also}{' '}
        <a href={links.linkedin} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-502-green transition-colors">LinkedIn</a>,{' '}
        <a href={links.instagram} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-502-green transition-colors">Instagram</a>,{' '}
        <a href={links.x} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-502-green transition-colors">X</a>{' '}
        y <a href={links.youtube} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-502-green transition-colors">YouTube</a>
      </p>
    </div>
  </div>
</section>
