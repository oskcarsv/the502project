---
interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

const t = {
  es: {
    label: 'QUE ES ESTO',
    title1: 'Una comunidad para quienes',
    titleHighlight: 'construyen',
    title2: 'desde Guatemala',
    description1: '502 es el codigo de Guatemala. The 502 Project es el espacio para quienes estan creando algo desde aca, o quieren empezar.',
    description2: 'No importa si es tech, una empresa, un side project o algo completamente diferente. Nos juntamos para compartir, hacer networking real y apoyarnos. Sin el bullshit corporativo.',
    cta: 'si construyes, eres de los nuestros.',
  },
  en: {
    label: 'WHAT IS THIS',
    title1: 'A community for those who',
    titleHighlight: 'build',
    title2: 'from Guatemala',
    description1: '502 is the country code for Guatemala. The 502 Project is the space for those creating something from here, or wanting to start.',
    description2: "Whether it's tech, a company, a side project, or something completely different. We come together to share, network for real, and support each other. No corporate bullshit.",
    cta: "if you build, you're one of us.",
  }
};

const text = t[lang];

---

<section class="relative py-24 sm:py-32">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Top: text content -->
    <div class="fade-in max-w-3xl mb-20">
      <span class="section-label mb-6 block">{text.label}</span>

      <h2 class="text-4xl sm:text-5xl lg:text-6xl leading-[1.05] mb-8">
        {text.title1}<br/>
        <span class="italic text-502-green">{text.titleHighlight}</span> {text.title2}
      </h2>

      <div class="space-y-5 text-gray-400 text-base sm:text-lg leading-relaxed">
        <p>{text.description1}</p>
        <p>{text.description2}</p>
        <p class="text-white text-xl sm:text-2xl font-serif italic">{text.cta}</p>
      </div>
    </div>

  </div>
</section>
