---

<footer class="border-t border-white/5 bg-502-black-deep">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-8">
      <!-- Logo & Mission -->
      <div class="md:col-span-5">
        <a href={lang === 'es' ? '/' : '/en'} class="inline-block mb-4">
          <Image
            src={logoGrande}
            alt="The 502 Project"
            class="h-14 w-auto"
            width={500}
            height={500}
          />
        </a>
        <p class="text-gray-400 text-sm max-w-sm mb-6">
          {text.mission}
        </p>

        <!-- Social icons -->
        <div class="flex gap-2">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="p-2 rounded-lg text-gray-500 hover:text-502-green hover:bg-white/5 transition-all"
              aria-label={social.name}
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={social.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Navigation -->
      <div class="md:col-span-3">
        <h4 class="text-xs text-gray-500 tracking-wider uppercase mb-4">{text.navigate}</h4>
        <ul class="space-y-2.5 text-sm">
          <li><a href={`${prefix}/events`} class="text-gray-400 hover:text-502-green transition-colors">{text.events}</a></li>
          <li><a href={`${prefix}/blog`} class="text-gray-400 hover:text-502-green transition-colors">{text.blog}</a></li>
          <li><a href={`${prefix}/builders`} class="text-gray-400 hover:text-502-green transition-colors">{text.builders}</a></li>
          <li><a href={`${prefix}/sponsorship-kit`} class="text-gray-400 hover:text-502-green transition-colors">{text.sponsors}</a></li>
          <li><a href={`${prefix}/code`} class="text-gray-400 hover:text-502-green transition-colors">{text.code}</a></li>
        </ul>
      </div>

      <!-- Community -->
      <div class="md:col-span-4">
        <h4 class="text-xs text-gray-500 tracking-wider uppercase mb-4">{text.community}</h4>
        <ul class="space-y-2.5 text-sm">
          <li>
            <a href={links.discord} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-502-green transition-colors">Discord</a>
          </li>
          <li>
            <a href={links.whatsapp} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-502-green transition-colors">WhatsApp</a>
          </li>
          <li>
            <a href="mailto:hello@the502project.com" class="text-gray-400 hover:text-502-green transition-colors">hello@the502project.com</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-gray-600">
        &copy; {new Date().getFullYear()} The 502 Project. {text.rights}
      </p>
      <div class="flex items-center gap-4">
        <p class="text-xs text-gray-600">
          {text.madeWith} <span class="text-red-500">&#9829;</span> {text.from}
        </p>
        <a
          href={lang === 'es' ? '/en' : '/'}
          class="text-xs text-gray-500 hover:text-502-green transition-colors"
        >
          {text.switchLang}
        </a>
      </div>
    </div>
  </div>
</footer>
