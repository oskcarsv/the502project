---
import { Image } from 'astro:assets';
import logoGrande from '../assets/logos/logo_grande.png';

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

const prefix = lang === 'es' ? '' : '/en';

const t = {
  es: {
    mission: 'Comunidad de builders, founders y dreamers construyendo desde Guatemala.',
    navigate: 'Navegar',
    events: 'Eventos',
    blog: 'Blog',
    code: 'Codigo de conducta',
    builders: 'Builders Program',
    sponsors: 'Sponsorship Kit',
    community: 'Comunidad',
    madeWith: 'Hecho con',
    from: 'desde Guatemala',
    switchLang: 'Switch to English',
    rights: 'Todos los derechos reservados.',
  },
  en: {
    mission: 'A community of builders, founders, and dreamers building from Guatemala.',
    navigate: 'Navigate',
    events: 'Events',
    blog: 'Blog',
    code: 'Code of Conduct',
    builders: 'Builders Program',
    sponsors: 'Sponsorship Kit',
    community: 'Community',
    madeWith: 'Made with',
    from: 'from Guatemala',
    switchLang: 'Cambiar a Espanol',
    rights: 'All rights reserved.',
  }
};

const text = t[lang];

const links = {
  discord: 'https://discord.gg/AZeuYhCu',
  whatsapp: 'https://chat.whatsapp.com/JNvMJwm9Y0aDOBEQj3sFkM',
  github: 'https://github.com/the502project',
  linkedin: 'https://www.linkedin.com/company/the502project/',
  instagram: 'https://www.instagram.com/_the502project/',
  x: 'https://x.com/the502project',
  youtube: 'https://www.youtube.com/@the-502-project',
  email: 'mailto:hello@the502project.com',
};

