---
interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

const t = {
  es: {
    label: 'IMPACTO',
    title: 'Crecimiento de la comunidad',
    titleHighlight: 'en numeros',
  },
  en: {
    label: 'IMPACT',
    title: 'Community growth',
    titleHighlight: 'in numbers',
  }
};

const text = t[lang];

const stats = [
  {
    value: '450+',
    label: lang === 'es' ? 'Builders activos' : 'Active builders',
    desc: lang === 'es' ? 'En Discord y WhatsApp' : 'On Discord & WhatsApp',
  },
  {
    value: '9',
    label: lang === 'es' ? 'Eventos realizados' : 'Events held',
    desc: lang === 'es' ? 'Presenciales y virtuales' : 'In-person & virtual',
  },
  {
    value: '6+',
    label: 'Sponsors',
    desc: lang === 'es' ? 'Empresas que nos apoyan' : 'Companies backing us',
  },
];
---

<section class="relative py-24 sm:py-32">
  <!-- Background accent - no overflow hidden so gradient bleeds naturally -->
  <div class="absolute inset-x-0 -top-40 -bottom-40 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] sm:w-[900px] sm:h-[600px] lg:w-[1200px] lg:h-[800px] bg-502-green/[0.04] rounded-full blur-[250px]"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="fade-in text-center mb-16">
      <span class="section-label mb-4 block">{text.label}</span>
      <h2 class="text-4xl sm:text-5xl lg:text-6xl leading-[1.05]">
        {text.title}<br/>
        <span class="italic text-502-green">{text.titleHighlight}</span>
      </h2>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6 max-w-4xl mx-auto">
      {stats.map((stat) => (
        <div class="stagger-item text-center p-6 sm:p-8 rounded-2xl border border-white/5 bg-502-surface/30">
          <div class="text-4xl sm:text-5xl lg:text-6xl font-serif text-white mb-2 stat-number">{stat.value}</div>
          <div class="text-sm text-white mb-1">{stat.label}</div>
          <div class="text-xs text-gray-500">{stat.desc}</div>
        </div>
      ))}
    </div>
  </div>
</section>
