---
import { Image } from 'astro:assets';
import notionLogo from '../assets/sponsors/notion-logo.png';
import finnyLogo from '../assets/sponsors/finny.png';

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

const label = lang === 'es' ? 'Nos apoyan' : 'Backed by';

const sponsors = [
  { name: 'Cursor', type: 'svg' as const },
  { name: 'Notion', type: 'image' as const, src: notionLogo, invert: true },
  { name: 'Finny', type: 'image' as const, src: finnyLogo, invert: false },
];
---

<section class="relative py-16 overflow-hidden border-y border-white/5">
  <div class="text-center mb-10">
    <span class="section-label">{label}</span>
  </div>

  <div class="relative">
    <!-- Fade edges -->
    <div class="absolute left-0 top-0 bottom-0 w-24 sm:w-40 bg-gradient-to-r from-502-black to-transparent z-10"></div>
    <div class="absolute right-0 top-0 bottom-0 w-24 sm:w-40 bg-gradient-to-l from-502-black to-transparent z-10"></div>

    <!-- Scrolling track -->
    <div class="flex animate-marquee items-center">
      {[...Array(6)].flatMap(() =>
        sponsors.map((sponsor) => (
          <div class="flex-shrink-0 mx-10 sm:mx-16 flex items-center justify-center py-4 opacity-60 hover:opacity-100 transition-opacity">
            {sponsor.type === 'svg' && sponsor.name === 'Cursor' && (
              <img src="/sponsors/cursor.svg" alt="Cursor" class="h-7 w-auto" />
            )}
            {sponsor.type === 'image' && (
              <Image
                src={sponsor.src!}
                alt={sponsor.name}
                class:list={["max-h-6 w-auto object-contain", { "invert": sponsor.invert }]}
                height={48}
              />
            )}
          </div>
        ))
      )}
    </div>
  </div>
</section>
