      { name: 'Web', href: 'https://www.theoscarvibes.com/', icon: `<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>` },
    ],
  },
  // Add more team members here as they join
];
---

<section class="relative py-24 sm:py-32">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="fade-in text-center mb-16">
      <span class="section-label mb-4 block">{text.label}</span>
      <h2 class="text-4xl sm:text-5xl lg:text-6xl leading-[1.05] mb-4">
        {text.title}<br/>
        <span class="italic text-502-green">{text.titleHighlight}</span>
      </h2>
      {text.subtitle && <p class="text-gray-400 max-w-md mx-auto">{text.subtitle}</p>}
    </div>

    <!-- Team Grid -->
    <div class="flex justify-center">
      <div class:list={[
        "grid gap-6",
        team.length === 1 ? "grid-cols-1 max-w-xs" : team.length === 2 ? "grid-cols-2 max-w-lg" : team.length === 3 ? "grid-cols-3 max-w-3xl" : "grid-cols-2 sm:grid-cols-3 lg:grid-cols-4"
      ]}>
        {team.map((member) => (
          <div class="stagger-item group text-center">
            <!-- Photo -->
            <div class="relative aspect-square rounded-2xl overflow-hidden mb-4 bg-502-surface border border-white/5 group-hover:border-502-green/30 transition-all duration-300">
              <Image
                src={member.image}
                alt={member.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                width={400}
                height={400}
              />

              <!-- Social overlay on hover -->
              <div class="absolute inset-0 bg-gradient-to-t from-502-black/80 via-502-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end justify-center pb-5">
                <div class="flex gap-2">
                  {member.socials.map((social) => (
                    <a
                      href={social.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="p-2.5 bg-white/10 backdrop-blur-sm rounded-full hover:bg-502-green/30 transition-colors"
                      aria-label={social.name}
                    >
                      <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                        <Fragment set:html={social.icon} />
                      </svg>
                    </a>
                  ))}
                </div>
              </div>
            </div>

            <!-- Info -->
            <h3 class="text-base sm:text-lg font-bold group-hover:text-502-green transition-colors">{member.name}</h3>
            <p class="text-xs text-gray-500 mt-1">{member.role}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
