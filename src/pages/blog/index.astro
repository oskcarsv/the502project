---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.localeCompare(a.data.pubDate));

const parseDate = (date: string) => new Date(date + 'T12:00:00');

const formatDate = (date: string) => {
  const d = parseDate(date);
  return d.toLocaleDateString('es-GT', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
};
---

<Layout
  title="Blog | the502project"
  description="Reflexiones y voces de la comunidad 502"
  lang="es"
>
  <div class="min-h-screen noise-bg">
    <Navbar lang="es" />

    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <section id="articulos" class="fade-in min-h-screen flex flex-col justify-center py-20">
        <span class="text-502-green text-xs tracking-wider mb-8 block">BLOG</span>

        <h1 class="text-4xl sm:text-5xl md:text-6xl mb-6">
          voces de la <span class="italic">comunidad</span>
        </h1>
        <p class="text-gray-400 text-lg max-w-lg mb-16">
          Reflexiones, aprendizajes y historias de builders desde Guatemala.
        </p>

        <div class="space-y-0">
          {posts.map((post) => (
            <a
              href={`/blog/${post.slug}`}
              class="stagger-item group border-b border-white/10 py-8 block"
            >
              <div class="min-w-0">
                <h2 class="text-xl md:text-2xl mb-2 group-hover:text-502-green transition-colors">
                  {post.data.title}
                </h2>
                <p class="text-gray-500 text-sm mb-3 line-clamp-2">
                  {post.data.description}
                </p>
                <div class="flex flex-wrap items-center gap-3 text-xs text-gray-600">
                  <span>{post.data.author}</span>
                  <span>·</span>
                  <time datetime={post.data.pubDate}>{formatDate(post.data.pubDate)}</time>
                </div>
              </div>
            </a>
          ))}
        </div>

        {posts.length === 0 && (
          <div class="fade-in border border-white/10 p-8 text-center">
            <p class="text-gray-400">próximamente más artículos</p>
          </div>
        )}
      </section>

    </main>
    <Footer lang="es" />
  </div>
</Layout>
