---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import PartnersMarquee from '../components/PartnersMarquee.astro';
import AboutSection from '../components/AboutSection.astro';
import StatsSection from '../components/StatsSection.astro';
import EventsSection from '../components/EventsSection.astro';
import TeamSection from '../components/TeamSection.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import BlogSection from '../components/BlogSection.astro';
import JoinCTA from '../components/JoinCTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="The 502 Project | Builders construyendo desde Guatemala"
  description="Comunidad de builders, founders y dreamers en Guatemala. Eventos, networking y proyectos."
  lang="es"
>
  <div class="noise-bg">
    <Navbar lang="es" />
    <Hero lang="es" />
    <PartnersMarquee lang="es" />
    <AboutSection lang="es" />
    <StatsSection lang="es" />
    <EventsSection lang="es" />
    <!-- <TestimonialsSection lang="es" /> -->
    <TeamSection lang="es" />
    <BlogSection lang="es" />
    <JoinCTA lang="es" />
    <Footer lang="es" />
  </div>
</Layout>
