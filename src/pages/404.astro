---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="404 | The 502 Project"
  description="Pagina no encontrada"
  lang="es"
>
  <div class="min-h-screen noise-bg flex flex-col">
    <Navbar lang="es" />
    <main class="flex-1 flex items-center justify-center px-4">
      <div class="text-center fade-in">
        <p class="text-502-green text-sm tracking-widest uppercase mb-4">ERROR</p>
        <h1 class="text-7xl sm:text-9xl font-serif mb-6">404</h1>
        <p class="text-gray-400 text-lg mb-8 max-w-md mx-auto">
          Esta pagina no existe. Tal vez se movio, o nunca existio.
        </p>
        <a
          href="/"
          class="inline-flex items-center gap-2 px-6 py-3 bg-white/5 border border-white/20 hover:border-502-green hover:bg-502-green/10 text-white rounded transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Volver al inicio
        </a>
      </div>
    </main>
    <Footer lang="es" />
  </div>
</Layout>
