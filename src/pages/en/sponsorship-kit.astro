---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Sponsorship Kit | the502project"
  description="invite your brand to build with a +300 community of top founders and builders in the region"
  lang="en"
>
  <div class="min-h-screen noise-bg">
    <Navbar lang="en" />

    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <section id="kit" class="min-h-screen flex flex-col justify-center py-20">
        <span class="text-502-green text-xs tracking-wider mb-8 block">SPONSORSHIP KIT</span>

        <h1 class="text-4xl sm:text-5xl md:text-6xl mb-6">
          put your brand in front of people <span class="italic">building</span> the region
        </h1>

        <p class="text-gray-400 text-lg max-w-xl mb-10">
          the502project is an active community of <span class="text-white">+300 top founders and builders in the region</span>.
          we connect brands with people shipping products, launching companies, and driving industry.
        </p>

        <div class="grid sm:grid-cols-3 gap-4">
          <div class="border border-white/10 p-4">
            <p class="text-2xl text-502-green mb-1">+300</p>
            <p class="text-xs text-gray-500">founders and builders</p>
          </div>
          <div class="border border-white/10 p-4">
            <p class="text-2xl text-502-green mb-1">IRL + online</p>
            <p class="text-xs text-gray-500">events and active community</p>
          </div>
          <div class="border border-white/10 p-4">
            <p class="text-2xl text-502-green mb-1">real fit</p>
            <p class="text-xs text-gray-500">tech and business audience</p>
          </div>
        </div>
      </section>

      <section id="benefits" class="fade-in min-h-screen flex flex-col justify-center py-24 border-t border-white/5">
        <span class="text-502-green text-xs tracking-wider mb-8 block">BENEFITS</span>

        <h2 class="text-4xl sm:text-5xl mb-10">
          what your brand can <span class="italic">gain</span>
        </h2>

        <div class="space-y-0 border-y border-white/10">
          <div class="stagger-item py-6 border-b border-white/10">
            <h3 class="text-2xl mb-2">direct access to talent and decision-makers</h3>
            <p class="text-gray-400">reach technical and business profiles already building products and companies.</p>
          </div>
          <div class="stagger-item py-6 border-b border-white/10">
            <h3 class="text-2xl mb-2">brand positioning in high-value spaces</h3>
            <p class="text-gray-400">presence in events, content, and channels where the community is actually engaged.</p>
          </div>
          <div class="stagger-item py-6 border-b border-white/10">
            <h3 class="text-2xl mb-2">activations and product showcase</h3>
            <p class="text-gray-400">show your solution in real contexts and get feedback from active founders and builders.</p>
          </div>
          <div class="stagger-item py-6">
            <h3 class="text-2xl mb-2">long-term community partnership</h3>
            <p class="text-gray-400">this is not just logo placement. we build collaborations with measurable impact.</p>
          </div>
        </div>
      </section>

      <section id="formats" class="fade-in min-h-screen flex flex-col justify-center py-24 border-t border-white/5">
        <span class="text-502-green text-xs tracking-wider mb-8 block">FORMATS</span>

        <h2 class="text-4xl sm:text-5xl mb-10">
          ways to <span class="italic">collaborate</span>
        </h2>

        <div class="grid sm:grid-cols-2 gap-4">
          <div class="stagger-item border border-white/10 p-5">
            <h3 class="text-xl mb-2">co-branded events</h3>
            <p class="text-gray-400 text-sm">meetups, workshops, and in-person experiences with intentional branding.</p>
          </div>
          <div class="stagger-item border border-white/10 p-5">
            <h3 class="text-xl mb-2">speaker slots and content</h3>
            <p class="text-gray-400 text-sm">share useful insights with the community without empty sales pitches.</p>
          </div>
          <div class="stagger-item border border-white/10 p-5">
            <h3 class="text-xl mb-2">product demos</h3>
            <p class="text-gray-400 text-sm">show your product to potential users and teams that make decisions.</p>
          </div>
          <div class="stagger-item border border-white/10 p-5">
            <h3 class="text-xl mb-2">multi-channel visibility</h3>
            <p class="text-gray-400 text-sm">presence across community channels, social media, and campaign assets.</p>
          </div>
        </div>
      </section>

      <section id="contact" class="fade-in min-h-screen flex flex-col justify-center py-24 border-t border-white/5">
        <span class="text-502-green text-xs tracking-wider mb-8 block">LET'S TALK</span>

        <h2 class="text-4xl sm:text-5xl mb-8">
          if there is a fit, <span class="italic">we build it together</span>
        </h2>

        <p class="text-gray-400 text-lg mb-10 max-w-xl">
          tell us your brand goals and we will propose a collaboration aligned with the community.
        </p>

        <div class="flex flex-wrap gap-3">
          <a
            href="mailto:hello@the502project.com?subject=Sponsorship%20Inquiry%20-%20The%20502%20Project"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-502-green text-502-black text-sm font-bold hover:bg-white transition-colors"
          >
            contact us
          </a>
        </div>
      </section>

    </main>
    <Footer lang="en" />
  </div>
</Layout>
