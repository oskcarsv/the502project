---
import Layout from '../../layouts/Layout.astro';

const applyUrl = 'https://theoscarvibes.notion.site/018f2e229ca783d2b95981cb21901e04?pvs=105';
---

<Layout
  title="Community Builders Program | the502project"
  description="the official team that operates and multiplies the impact of the502project in Guatemala. apply and build community from the inside."
  lang="en"
>
  <div class="min-h-screen grid-bg">
    <!-- Side Index Navigation (desktop) -->
    <nav class="hidden lg:flex fixed left-8 top-1/2 -translate-y-1/2 flex-col gap-4 z-50">
      <a href="/en" class="group flex items-center gap-3">
        <span class="relative w-2 h-2 flex items-center justify-center">
          <span class="absolute w-1.5 h-1.5 rounded-full bg-gray-600 group-hover:opacity-0 transition-opacity"></span>
          <svg class="absolute w-3 h-3 text-502-green opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
        </span>
        <span class="text-xs text-gray-500 group-hover:text-502-green transition-colors">home</span>
      </a>
      <a href="#community" class="nav-item group flex items-center gap-3">
        <span class="nav-indicator"></span>
        <span class="text-xs text-gray-500 group-hover:text-502-green transition-colors">community</span>
      </a>
      <a href="#program" class="nav-item group flex items-center gap-3">
        <span class="nav-indicator"></span>
        <span class="text-xs text-gray-500 group-hover:text-502-green transition-colors">program</span>
      </a>
      <a href="#benefits" class="nav-item group flex items-center gap-3">
        <span class="nav-indicator"></span>
        <span class="text-xs text-gray-500 group-hover:text-502-green transition-colors">benefits</span>
      </a>
      <a href="#rules" class="nav-item group flex items-center gap-3">
        <span class="nav-indicator"></span>
        <span class="text-xs text-gray-500 group-hover:text-502-green transition-colors">rules</span>
      </a>
      <a href="#apply" class="nav-item group flex items-center gap-3">
        <span class="nav-indicator"></span>
        <span class="text-xs text-gray-500 group-hover:text-502-green transition-colors">apply</span>
      </a>
    </nav>

    <!-- Top bar -->
    <div class="fixed top-0 left-0 right-0 z-50 px-6 py-4 flex items-center justify-end">
      <div class="flex items-center gap-4 text-xs text-gray-500">
        <a href="/en" class="hover:text-white">home</a>
        <a href="/en/events" class="hover:text-white">events</a>
        <a href="/en/blog" class="hover:text-white">blog</a>
        <a href={applyUrl} target="_blank" rel="noopener noreferrer" class="hover:text-502-green text-white border border-white/20 px-3 py-1 hover:border-502-green transition-colors">apply →</a>
        <a href="/builders" class="hover:text-502-green border-l border-white/10 pl-4">es</a>
      </div>
    </div>

    <main class="max-w-3xl mx-auto px-6 lg:px-0 lg:ml-44 xl:ml-56">

      <!-- Hero Section -->
      <section id="community" class="min-h-screen flex flex-col justify-center py-20">
        <div class="flex items-center gap-3 mb-8">
          <span class="text-502-green text-xs tracking-wider">COMMUNITY BUILDERS PROGRAM</span>
          <span class="w-8 h-px bg-502-green/40"></span>
          <span class="text-xs text-gray-600">by the502project</span>
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl mb-6 leading-tight">
          build Guatemala<br/>
          <span class="italic text-502-green">from the inside</span>
        </h1>

        <p class="text-gray-400 text-lg max-w-xl mb-10">
          the502project is a community built to accelerate the tech and entrepreneurship ecosystem in Guatemala.
          we connect people, universities and companies to create spaces for learning, collaboration and building.
        </p>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-0 border border-white/10 mb-12">
          <div class="p-5 border-r border-white/10">
            <p class="text-3xl text-502-green mb-1">+450</p>
            <p class="text-xs text-gray-500">active builders</p>
          </div>
          <div class="p-5 border-r border-white/10">
            <p class="text-3xl text-502-green mb-1">+10</p>
            <p class="text-xs text-gray-500">events in 4 months</p>
          </div>
          <div class="p-5">
            <p class="text-3xl text-502-green mb-1">502</p>
            <p class="text-xs text-gray-500">Guatemala-based</p>
          </div>
        </div>

        <p class="text-gray-400 max-w-xl">
          we run meetups, workshops, talks and programs. we connect the community with mentorship, opportunities and support networks.
          <span class="text-white">now we're opening the team that makes it happen.</span>
        </p>
      </section>

      <!-- Program Section -->
      <section id="program" class="fade-in min-h-screen flex flex-col justify-center py-24 border-t border-white/5">
        <span class="text-502-green text-xs tracking-wider mb-8 block">THE PROGRAM</span>

        <h2 class="text-4xl sm:text-5xl mb-6">
          it's not just about <span class="italic">suggesting events</span>
        </h2>

        <p class="text-gray-400 text-lg max-w-xl mb-12">
          the Community Builders Program is the official team of members that helps operate the502project
          and multiply its impact in Guatemala. it's about taking <span class="text-white">real ownership</span> of initiatives.
        </p>

        <!-- What builders do -->
        <div class="space-y-0 border-y border-white/10">
          <div class="stagger-item py-6 border-b border-white/10 group">
            <div class="flex items-start gap-4">
              <span class="text-502-green mt-1 text-sm">01</span>
              <div>
                <h3 class="text-xl mb-2 group-hover:text-502-green transition-colors">support internal operations</h3>
                <p class="text-gray-400 text-sm">management and execution of events, initiatives and programs. not just suggesting, but making things happen.</p>
              </div>
            </div>
          </div>
          <div class="stagger-item py-6 border-b border-white/10 group">
            <div class="flex items-start gap-4">
              <span class="text-502-green mt-1 text-sm">02</span>
              <div>
                <h3 class="text-xl mb-2 group-hover:text-502-green transition-colors">lead your own activities</h3>
                <p class="text-gray-400 text-sm">propose and execute meetups, talks, workshops and study groups. turn ideas into reality.</p>
              </div>
            </div>
          </div>
          <div class="stagger-item py-6 border-b border-white/10 group">
            <div class="flex items-start gap-4">
              <span class="text-502-green mt-1 text-sm">03</span>
              <div>
                <h3 class="text-xl mb-2 group-hover:text-502-green transition-colors">volunteer at events</h3>
                <p class="text-gray-400 text-sm">staff, logistics, registration, photo/video, speakers support at the502project and allied community events.</p>
              </div>
            </div>
          </div>
          <div class="stagger-item py-6 border-b border-white/10 group">
            <div class="flex items-start gap-4">
              <span class="text-502-green mt-1 text-sm">04</span>
              <div>
                <h3 class="text-xl mb-2 group-hover:text-502-green transition-colors">activate your university or community</h3>
                <p class="text-gray-400 text-sm">organize activities at your university or other communities using the the502project network.</p>
              </div>
            </div>
          </div>
          <div class="stagger-item py-6 group">
            <div class="flex items-start gap-4">
              <span class="text-502-green mt-1 text-sm">05</span>
              <div>
                <h3 class="text-xl mb-2 group-hover:text-502-green transition-colors">operational contributions</h3>
                <p class="text-gray-400 text-sm">coordination, communication, follow-up, partnerships and improvements to the community playbook.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Benefits Section -->
      <section id="benefits" class="fade-in min-h-screen flex flex-col justify-center py-24 border-t border-white/5">
        <span class="text-502-green text-xs tracking-wider mb-8 block">BENEFITS</span>

        <h2 class="text-4xl sm:text-5xl mb-6">
          what you <span class="italic">get</span>
        </h2>

        <p class="text-gray-400 text-lg max-w-xl mb-12">
          active builders gain exposure within the ecosystem and acquire hands-on experience in
          organizing, leading and operating programs.
        </p>

        <div class="grid sm:grid-cols-2 gap-4">
          <div class="stagger-item border border-white/10 p-6 hover:border-502-green/40 transition-colors group">
            <div class="w-8 h-8 border border-502-green/30 flex items-center justify-center mb-4 group-hover:border-502-green transition-colors">
              <svg class="w-4 h-4 text-502-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="text-lg mb-2">real mentorship</h3>
            <p class="text-gray-400 text-sm">mentorship from Cursor ambassadors in Guatemala and the founding team of the502project.</p>
          </div>

          <div class="stagger-item border border-white/10 p-6 hover:border-502-green/40 transition-colors group">
            <div class="w-8 h-8 border border-502-green/30 flex items-center justify-center mb-4 group-hover:border-502-green transition-colors">
              <svg class="w-4 h-4 text-502-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="text-lg mb-2">partner perks</h3>
            <p class="text-gray-400 text-sm">credits and access to AI platforms and tools from partner companies (subject to availability).</p>
          </div>

          <div class="stagger-item border border-white/10 p-6 hover:border-502-green/40 transition-colors group">
            <div class="w-8 h-8 border border-502-green/30 flex items-center justify-center mb-4 group-hover:border-502-green transition-colors">
              <svg class="w-4 h-4 text-502-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-lg mb-2">sponsor network</h3>
            <p class="text-gray-400 text-sm">access to the sponsor network to fund your own events (for events approved by the502project).</p>
          </div>

          <div class="stagger-item border border-white/10 p-6 hover:border-502-green/40 transition-colors group">
            <div class="w-8 h-8 border border-502-green/30 flex items-center justify-center mb-4 group-hover:border-502-green transition-colors">
              <svg class="w-4 h-4 text-502-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
              </svg>
            </div>
            <h3 class="text-lg mb-2">leadership programs</h3>
            <p class="text-gray-400 text-sm">support to apply for Cursor Ambassador, Notion Campus Leaders and other programs.</p>
          </div>

          <div class="stagger-item border border-white/10 p-6 hover:border-502-green/40 transition-colors group sm:col-span-2">
            <div class="flex items-start gap-6">
              <div class="w-8 h-8 border border-502-green/30 flex items-center justify-center flex-shrink-0 mt-1 group-hover:border-502-green transition-colors">
                <svg class="w-4 h-4 text-502-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg mb-2">official team + priority access</h3>
                <p class="text-gray-400 text-sm">access to the exclusive the502project mentor network, priority at events and programs, and being part of the team that builds the community.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Rules Section -->
      <section id="rules" class="fade-in min-h-screen flex flex-col justify-center py-24 border-t border-white/5">
        <span class="text-502-green text-xs tracking-wider mb-8 block">RULES</span>

        <h2 class="text-4xl sm:text-5xl mb-6">
          simple and <span class="italic">clear</span>
        </h2>

        <p class="text-gray-400 text-lg max-w-xl mb-12">
          the program requires real commitment. not much, but consistent.
        </p>

        <div class="space-y-0 border border-white/10">
          <div class="stagger-item p-6 border-b border-white/10 flex gap-6">
            <span class="text-502-green text-xl font-bold flex-shrink-0">1×</span>
            <div>
              <h3 class="text-lg mb-1">minimum monthly activity</h3>
              <p class="text-gray-400 text-sm">1 contribution per month: event, volunteering or another contribution agreed with the team. simple.</p>
            </div>
          </div>
          <div class="stagger-item p-6 border-b border-white/10 flex gap-6">
            <span class="text-502-green text-xl flex-shrink-0">✓</span>
            <div>
              <h3 class="text-lg mb-1">event approval</h3>
              <p class="text-gray-400 text-sm">to use the the502project branding (and/or partners), the event must be approved by the team first.</p>
            </div>
          </div>
          <div class="stagger-item p-6 border-b border-white/10 flex gap-6">
            <span class="text-502-green text-xl flex-shrink-0">↗</span>
            <div>
              <h3 class="text-lg mb-1">brand standards</h3>
              <p class="text-gray-400 text-sm">approved events must follow the code of conduct, brand guidelines and basic logistics defined by the502project.</p>
            </div>
          </div>
          <div class="stagger-item p-6 flex gap-6">
            <span class="text-502-green text-xl flex-shrink-0">⊘</span>
            <div>
              <h3 class="text-lg mb-1">inactivity = benefits pause</h3>
              <p class="text-gray-400 text-sm">no contribution in the month means inactive status and loss of priority/benefits until reactivated with a new contribution.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Apply Section -->
      <section id="apply" class="fade-in min-h-screen flex flex-col justify-center py-24 border-t border-white/5">
        <span class="text-502-green text-xs tracking-wider mb-8 block">APPLY</span>

        <h2 class="text-4xl sm:text-5xl mb-6">
          ready to<br/><span class="italic">build from the inside?</span>
        </h2>

        <p class="text-gray-400 text-lg max-w-xl mb-4">
          if you're passionate about Guatemala's tech and entrepreneurship ecosystem, and want to take real ownership of something that matters, this program is for you.
        </p>

        <p class="text-gray-500 text-sm max-w-xl mb-12">
          if accepted, you'll receive onboarding with the full playbook: how to propose and execute initiatives, use branding and request sponsor support.
        </p>

        <!-- CTA box -->
        <div class="border border-502-green/30 p-8 mb-8 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-502-green/5 -translate-y-1/2 translate-x-1/2 rounded-full"></div>
          <p class="text-xs text-gray-500 mb-4 tracking-wider">ONE STEP</p>
          <h3 class="text-2xl mb-6">complete the application form</h3>
          <a
            href={applyUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 px-6 py-3 bg-502-green text-502-black text-sm font-bold hover:bg-white transition-colors"
          >
            apply to the program
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <p class="text-sm text-gray-500 mb-6">
          we review each application carefully. <span class="text-white">we'll get back to you within 1 to 2 weeks</span> by whatsapp.
        </p>

        <p class="text-xs text-gray-600">
          questions? reach us at <a href="mailto:hello@the502project.com" class="text-gray-400 hover:text-502-green transition-colors">hello@the502project.com</a>
        </p>
      </section>

      <!-- Footer -->
      <footer class="py-16 border-t border-white/5">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-502-green" viewBox="0 0 100 100" fill="currentColor">
              <rect x="10" y="10" width="35" height="35" rx="2"/>
              <path d="M55 10 Q90 10 90 45 L55 45 Z"/>
              <path d="M10 55 Q10 90 45 90 L45 55 Z"/>
              <path d="M55 55 Q90 55 90 90 L55 90 Z"/>
            </svg>
            <span class="text-xs text-gray-500">the502project</span>
          </div>

          <div class="flex flex-wrap gap-4 text-xs text-gray-500">
            <a href="/en/code" class="hover:text-502-green">code of conduct</a>
            <a href="/en/sponsorship-kit" class="hover:text-502-green">sponsors</a>
            <a href="mailto:hello@the502project.com" class="hover:text-502-green">contact</a>
          </div>
        </div>
      </footer>

    </main>
  </div>

  <script>
    const sections = document.querySelectorAll('section[id]');
    const navItems = document.querySelectorAll('.nav-item');

    window.addEventListener('scroll', () => {
      let current = '';
      sections.forEach(section => {
        const sectionTop = (section as HTMLElement).offsetTop;
        if (scrollY >= sectionTop - 300) {
          current = section.getAttribute('id') || '';
        }
      });

      navItems.forEach(item => {
        item.classList.remove('active');
        if (item.getAttribute('href') === `#${current}`) {
          item.classList.add('active');
        }
      });
    });
  </script>
</Layout>
